pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	scene="title"
	char_flip=false
	char_sprite=64
	x=30
	y=50
	t=0
	-- intro vars
	red1= 0
	
end

function _update()
		if scene=="title" then
			title_update()
		elseif scene=="charsel" then
			charsel_update()
		elseif scene=="beach" then
			beach_update()
		end
end

function _draw()

		if scene=="title" then
			title_draw()
		elseif scene=="charsel" then
			charsel_draw()
		elseif scene=="beach" then
			beach_draw()
		end		
	
end

------------------------
--- title screen -------
------------------------

function title_update()
	if btnp(❎) then
		scene="charsel"
	end
	
	
end



function title_draw()
	cls(5)
	
	--background
	
	-- champs a
	spr(64,50,100)
	
	-- champs b
	spr(87,10,10, true, false)
	
	print("\^w\^tsuper pico",21,45,10)
	print("\^w\^tsmash bros",21,58,10)
	
	
	

end


-->8
-- selection screen

function charsel_update()

end



function charsel_draw()

	cls(0)
	
	

end
