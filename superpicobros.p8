pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	scene="title"
	char_flip=false
	char_sprite=64
	x=30
	y=50
	t=0
	-- intro vars
	red1= 0
	
end

function _update()
		if scene=="title" then
			title_update()
		elseif scene=="charsel" then
			charsel_update()
		elseif scene=="beach" then
			beach_update()
		end
end

function _draw()

		if scene=="title" then
			title_draw()
		elseif scene=="charsel" then
			charsel_draw()
		elseif scene=="beach" then
			beach_draw()
		end		
	
end

------------------------
--- title screen -------
------------------------

function title_update()
	if btnp(❎) then
		scene="charsel"
	end
	
	
end



function title_draw()
	cls(0)
	
	--background
	circ(64,64,63,5)
	
	-- champs a
	spr(112,0,100)
	spr(71,8,100)
	spr(87,16,100)
	spr(103,24,100)
	spr(80,32,100)
	spr(119,40,100)
	spr(96,48,100)
	spr(64,54,100) 
	-- champs b

	spr(128,72,100)
	spr(144,80,100)
	spr(160,88,100)
	spr(176,96,100)
	spr(135,104,100)
	spr(151,112,100)
	spr(167,120,100)
	print("\^w\^tsuper pico",25,40,10)
	print("\^w\^tsmash bros",25,53,10)

end


-->8
-- selection screen

function charsel_update()

end



function charsel_draw()

	cls(0)
	
	

end
