pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	scene="title"
	char_flip=false
	char_sprite=64
	cam_x=0
	cam_y=0
	t=0
	title_anim={54,55,56,57,58}
end

function _update()
		if scene=="title" then
			update_main()
		elseif scene=="game" then
			update_game()
		end
end


function _draw()
		if scene=="title" then
			draw_main()
		elseif scene=="game" then
			draw_game()
		end		
end

-->8
--main title scene

function update_main()


	t=t+1
	
	if btnp(❎) then
		scene="game"
	end
end

function draw_main()
	cls()
	
	--diablo pic
	spr(11,24,9,5,4)
	spr(11,64,9,5,4,true,false)
	--diablo text
	-- d
	spr(1,12,60,3,2)
	spr(1,12,76,3,2, false, true)
	-- i
	spr(32,33,60,2,2)
	-- a
	spr(4,45,60,2,4) 
	-- b
	spr(34,61,60,2,1)
	spr(34,61,68,2,1)
	-- l
	spr(32,75,60,2,2)
	spr(16,84,68,1,1)
	-- o
	spr(6,95,60,3,2)
	spr(6,95,76,3,2, false, true)
	print("\^w\^tpico",50,45,10)
	--- fire 54-58

	spr(title_anim[flr(t/4)%5+1],12,52)
	spr(title_anim[flr(t/4)%5+1],18,52)
	spr(title_anim[flr(t/4)%5+1],36,54)
	spr(title_anim[flr(t/4)%5+1],48,52)
	spr(title_anim[flr(t/4)%5+1],65,54)
	spr(title_anim[flr(t/4)%5+1],78,52)
	spr(title_anim[flr(t/4)%5+1],100,52)
	spr(title_anim[flr(t/4)%5+1],107,53)
	
	print("press ❎ to start",30,107,7)
end

-->8
--game scene

function update_game()
	if btnp(❎) then
		scene="title"
	end
	-- north / btn left
	if (btn(0) and cam_x > 0) then
	 cam_x -= 1
	 cam_y -= 1
	 char_flip=false
	 char_sprite=66
	end
	-- south / btn right
 if (btn(1) and cam_x < 895) then
  cam_x += 1
  cam_y += 1
  char_flip=false
  char_sprite=64
 end 
 -- east / btn up
 if (btn(2) and cam_y > 0) then
 	cam_y -= 1
 	cam_x += 1
 	char_flip=true
 	char_sprite=66
 end
 -- west / btn down
 if (btn(3) and cam_y < 127) then
 	cam_y += 1
 	cam_x -= 1
 	char_flip=true
 	char_sprite=64
	end
 -- (the camera stops with the bottom of
 -- the screen at row 32.)

end

function draw_game()
	cls()

	camera(cam_x, cam_y)

 -- draw the entire map at (0, 0), allowing
 -- the camera and clipping region to decide
 -- what is shown
 map(0, 0, 0, 0, 128, 32)
  
 -- reset the camera then print the camera
 -- coordinates on screen
 camera()
	
	--char
	spr(char_sprite,60,40,2,4,char_flip, false)
	
 --print('('..cam_x..', '..cam_y..')', 0, 0, 7)
	
	spr(68,10,10,2,4)
	
	-- enemy
	
	
	-- interface
	rectfill(0, 114, 127, 127, 0)
	-- health orb
	circfill(28, 118, 12, 1)
	clip(15,115,26,130)
	-- healh bar
	circfill(28, 118, 11, 8)
	clip()
	-- mana orb
	circfill(99, 118, 12, 1)
	clip(85,118,99,130)
	--mana bar
	circfill(99, 118, 11, 12)
	clip()
	-- mana pots
	spr(50,120,120,1,1)
	print(6,115,122,12)
	-- health pots
	spr(51,0,120,1,1)
	print(4,10,122,8)
	
end
