pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--pico international soccer
--by elemento26
--v.0.0.1

function _init()
 player_init()

end

function _update()
	--select_update()
	game_update()
end

function _draw()
 --select_draw()
 game_draw()
end
-->8
-- title
-->8
-- select team

function select_update()

end

function select_draw()
	cls(0)
	
	-- team slection
	pal()
	sspr(8,24,8,8,8,16,16,16) --arg
	sspr(16,24,8,8,40,16,16,16) --bra
	sspr(24,24,8,8,72,16,16,16) --arg
	sspr(32,24,8,8,104,16,16,16) --
	sspr(40,24,8,8,8,40,16,16) --arg
	sspr(48,24,8,8,40,40,16,16) --
	sspr(56,24,8,8,72,40,16,16) --jap
	sspr(64,24,8,8,104,40,16,16) --esp
	-- p1 cursor
	sel_x = 12 + 28
	sel_y = 9
	spr(57 ,sel_x,sel_y+7,1,1) -- selector
	spr(58 ,sel_x,sel_y,1,1) -- selector
	-- p2 cursor
	sel2_x = 12 + 100
	sel2_y = 9 + 24
	pal(12,8) 
	spr(57 ,sel2_x,sel2_y+7,1,1) -- selector
	pal()
	spr(59 ,sel2_x,sel2_y,1,1) -- selector
	
	-- texts
	print("select your team",32,3,10)
	print("brazil",26,92,10)
	print("\^w\^tvs",57,74,10)
	print("spain",80,92,10)
	
	-- field
	
	rectfill(0, 100, 127,127,3)
	rectfill(0, 100, 127,103,11)
	rectfill(0, 108, 127,114,11)
	rectfill(0, 124, 127,127,11)
	line(63, 100, 64, 127,7 )
	circ(64, 120, 18, 7)
	spr(48, 60, 115,1,1)

	-- p1 colors
	pal(14,10) -- shirt
	pal(9,12) -- pants
	pal(11,12) -- socks
	pal(15,4) -- skin
	-- p1 cloth & char
	spr(0, 30, 63,2,3)
	spr(2, 42, 100,1,3)
	pal()
	-- p2 colors
	pal(14,8) -- shirt
	pal(9,12) -- pants
	pal(11,1) -- socks
	-- p2 cloth & char
	spr(0,82, 63,2,3)
	spr(2, 78, 100,1,3, true, false)
	
	spr(58,16,72,1,1)
	spr(59,104,72,1,1)
	
end
-->8
--player

function player_init()
	x = 50
	y = 50
	t = 0
end

function player_update()
 t = t + 1
 if btn(0) then x = x - 1 end
 if btn(1) then x = x + 1 end
 if btn(2) then y = y - 1 end
 if btn(3) then y = y + 1 end
end

function player_draw()
 cls()
 spr(0, x, y,2,3)
end

-->8
-- game

function game_update()

	t = t + 1
 if btn(0) then x = x - 1 end
 if btn(1) then x = x + 1 end
 if btn(2) then y = y - 1 end
 if btn(3) then y = y + 1 end

end

function game_draw()

	cls(3)
	
	-- field
	--- sky
	rectfill(0, 0, 127,25,12)
	--- grass -- todo: loop
	rectfill(0,30,127,31,11)
	rectfill(0,33,127,35,11)
	rectfill(0,40,127,43,11)
	rectfill(0,50,127,55,11)
	rectfill(0,63,127,69,11)
	rectfill(0,80,127,90,11)
	rectfill(0,107,127,124,11)
	--- lines
	line(63, 30, 64, 127,7 )
	line(0, 30, 127,30, 7 )
	circ(64, 120, 18, 7)
	
 -- adds
 palt(0, false)
 spr(112,0,20,6,1)
 spr(112,48,20,6,1)
 spr(112,96,20,6,1)
 palt()
	-- ball
	spr(48, 62, 64,1,1)
	
	-- players
	--- p1 colors
	pal(14,10) -- shirt
	pal(9,12) -- pants
	pal(11,12) -- socks
	pal(15,4) -- skin
	spr(2, 20, 60,1,3)
	spr(2, 88, 20,1,3)
	
	-- p1 char
	spr(2, x, y,1,3)
	-- p1 marker
	spr(57, x, y-8,1,1)
	spr(58, x, y-16,1,1)
	pal()
	
	-- p2 colors
	pal(14,8) -- shirt
	pal(9,12) -- pants
	pal(11,1) -- socks
	spr(2, 78, 69,1,3, true, false)
	spr(2, 118, 89,1,3, true, false)
	pal()
	-- hud
	line(64, 1, 65, 1, 14) --2px center mark
 print("\^w\^t0-0",54,7,7)
 print("13:37",55,1,10)
 spr(50, 43,3,1,1) -- flag 1
 spr(56, 79,3,1,1) -- flag 2
 -- name plate p1
 rectfill(1, 120,39,126,6)
 -- name p1
 print("09",2,121,0)
 print("castolo",12,121,7)
 -- name plate p2
 rectfill(96, 120, 126,126,6)
 -- name p2
 print("08",119,121,0)
 print("pedri",97,121,7)
end
