pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	scene="title"
	char_flip=false
	char_sprite=64
	x=30
	y=50
	t=0
end

function _update()
		if scene=="title" then
			title_update()
		elseif scene=="charsel" then
			charsel_update()
		elseif scene=="beach" then
			beach_update()
		end
end

function _draw()

		if scene=="title" then
			title_draw()
		elseif scene=="charsel" then
			charsel_draw()
		elseif scene=="beach" then
			beach_draw()
		end		
	
end

-->8
--main title scene

function title_update()


	if btnp(❎) then
		scene="beach"
	end
end

function title_draw()


	cls()
	-- background
	rectfill(0,0,127,8,1)
	rectfill(0,8,127,16,12)
	rectfill(0,16,127,32,7)
	rectfill(0,32,127,40,12)
	rectfill(0,40,127,48,9)
	rectfill(0,48,127,56,9)
	rectfill(0,56,127,62,12)
	rectfill(0,62,127,70,4)
	rectfill(0,70,127,78,1)
	rectfill(0,78,127,86,0)

	-- text
	print("\^w\^tpicojammers",21,45,10)
	-- todo: disc animation
	spr(119,60,58,1,1)
	print("press ❎ to start",30,107,7)
end


-------------------------
-- select player
-------------------------

function charsel_update()

end

function charsel_draw()

end


-------------------------
-- select stage
-------------------------

function stagesel_update()

end

function stagesel_draw()

end


-->8
-- select player & stage
-->8
-- beach lvl
function beach_update()
  t = t + 1
  if btn(0) then x = x - 1 end
  if btn(1) then x = x + 1 end
  if btn(2) then y = y - 1 end
  if btn(3) then y = y + 1 end
end

function beach_draw()
	-- floor
	rectfill(0,0,127,127,15)
	map(0, 0, 0, 0, 16, 16)
	-- lines
	line(10,79,117,79,13)
	line(10,33,10,118,13)
	line(117,33,117,118,13)
	line(10,33,117,33,13)
	line(10,118,117,118,13)
	-- net
	line(63,24,63,127,9)
	line(64,24,64,127,10)
	-- bumpers
	--- yellow left top
	spr(0,1,24,1,1)
	spr(16,1,32,1,1)
	spr(0,1,40,1,1,false,true)
	--- yellow right top
	spr(0,119,24,1,1,true,false)
	spr(16,119,32,1,1,true,false)
	spr(0,119,40,1,1,true,true)
	-- change color
	pal(10,14)
	--- pink mid left
	spr(0,1,48,1,1)
	spr(16,1,56,1,1)
	spr(16,1,64,1,1)
	spr(16,1,72,1,1)
	spr(16,1,80,1,1)
	spr(0,1,88,1,1,false,true)
		--- pink mid right
	spr(0,119,48,1,1,true,false)
	spr(16,119,56,1,1,true,false)
	spr(16,119,64,1,1,true,false)
	spr(16,119,72,1,1,true,false)
	spr(16,119,80,1,1,true,false)
	spr(0,119,88,1,1,true,true)
	-- change color
	pal()
	--- yellow left bottom
	spr(0,1,96,1,1)
	spr(16,1,104,1,1)
	spr(0,1,112,1,1,false,true)
	--- yellow right bottom
	spr(0,119,96,1,1,true,false)
	spr(16,119,104,1,1,true,false)
	spr(0,119,112,1,1,true,true)
	-- referee
	---circfill(61, 113, 3, 10)
	-- p1 
	spr(64, x, y,2,3)
	-- p2
	pal(3,1)
	pal(11,12)
	pal(8,12)
	spr(64, 90, 55,2,3, true, false)
	-- ball
	spr(119, x+15, y+9)
	-- hud
	print("\^w\^t15-00",45,2,10)
 
end
