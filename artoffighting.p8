pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--pico art of fighting
--by elemento26
--v.0.0.1

function _init()

	scene="game"
	player_x = 15
	player_y = 90
	cpu_x = 70
	distance = 20
	zoom_lvl = 1
	
	prev_sgn = 1
	shake = 0
	frame = 0
	
end

function _update()

	if scene=="title" then
		title_update()
	elseif scene=="game" then
		game_update()
	end
		
end


function _draw()

		if scene=="title" then
			title_draw()
		elseif scene=="game" then
			game_draw()
		end		
	
end


-->8
-- title

function title_update()
	if btnp(❎) then
		scene="game"
	end

end

function title_draw()

	cls(0)
	
	print("\^w\^tpico",49,15,10)
	print("\^w\^tart of",48,30)
 	print("\^w\^tfighting",13,45)

end
-->8
-- game

function game_update()

	if btn(⬅️) then player_x-=1 end

	if btn(➡️) then player_x+=1 end

	distance = cpu_x - player_x

	-- signo 
	sgn = distance > 0 and 1 or -1

	-- detectar cruce 
	snap = (sgn ~= prev_sgn) and 0.3 or 0.1

	-- distancia absoluta (sin abs())
	d = distance * sgn

	-- clamp manual (mれくs barato que mid)
	if d < 40 then d = 40 end
	if d > 60 then d = 60 end

	-- zoom (constantes precalculadas)
	-- (1.8 - 0.9)/(60-40) = 0.045
	target_zoom = 1.8 - (d - 40) * 0.045

	-- suavizado
	zoom_lvl += (target_zoom - zoom_lvl) * snap

	-- altura ligada (sin mれくs cれくlculos)
	player_y = 110 - zoom_lvl * 30

	-- trigger golpe
	if btnp(❎) then
		shake = 3
	end

	-- decay simple (sin multiplicaciones caras)
	if shake > 0 then
		shake -= 0.3
	end

	prev_sgn = sgn

end

function game_draw()

	cls(12)
	
	backg_draw()

	-- shake sin rnd()
	cam_x = shake > 0 and (frame%2*shake - shake/2) or 0
	cam_y = shake > 0 and ((frame+1)%2*shake - shake/2) or 0

	frame += 1

 print("player_x:",0,120,15)
	print(player_x,40,120,15)
	
	print("distance:",80,120,15)
	print(distance,120,120,15)

	-- p1
	sspr(0,0,16,64,
		player_x + cam_x,
		player_y + cam_y,
		16*zoom_lvl,
		64*zoom_lvl
	)

	-- cpu
	sspr(16,0,16,64,
		cpu_x + cam_x,
		player_y + cam_y,
		16*zoom_lvl,
		64*zoom_lvl,
		true,false
	)
	
	-- hud
	print("\^w\^t99",58,3,0)
	print("\^w\^t99",57,2,9)
	-- p1 health bar
	rect(2, 2, 54, 8, 7)
	rectfill(3,3, 53,7,0)
	rectfill(3,3, 37,7,8)
	-- p2 health bar
	rect(73, 2, 125, 8, 7)
	rectfill(74,3, 124,7,0)
	rectfill(74,3, 98,7,8)
	-- player names
	print("ryu sakazaki",2,10,7)
	print("robert garcia",75,10,7)
	
end
-->8
--- background

function backg_update()

end


function backg_draw()

	-- floor
	rectfill(0, 100, 127, 127, 4)
	-- extras
	rectfill(0, 82, 127, 84, 8)
	rectfill(0, 87, 127, 90, 8)
	rectfill(0, 94, 127, 98, 8)
	--ceiling
	rectfill(0, 17, 127, 40, 2)
	rectfill(0, 17, 127, 25, 1)
	rectfill(0, 0, 127, 17, 0)
 -- columns
 circfill(30,97,8,2)
 rectfill(22,40 ,38,95, 2)
 rectfill(37,40,38,99,8)
 
 circfill(90,97,8,2)
 rectfill(82,40,98,95, 2)
 rectfill(97,40,98,99,8)
 
 rect(82,60,88,70,0)
 rectfill(82,61,87,69,7)
 
end
